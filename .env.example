# Plantilla de variables de entorno. Copiar a .env y rellenar.
# NUNCA poner valores reales aquí ni versionar el .env.

# Entorno de ejecución: development | production
ENVIRONMENT=development

# Supabase (proyecto de datos, auth y secretos)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Secreto JWT legacy (HS256). Solo para proyectos Supabase con secreto
# compartido; los proyectos nuevos firman con llaves asimétricas y se
# verifican vía JWKS usando SUPABASE_URL (no requieren este valor).
SUPABASE_JWT_SECRET=

# Llave de cifrado simétrico para tokens de terceros (Fernet, urlsafe-base64 de 32 bytes)
ENCRYPTION_KEY=

# Steam Web API key (servidor; nunca expuesta al cliente)
STEAM_API_KEY=

# client_id de la app de Trakt (Cine y TV, D41)
TRAKT_CLIENT_ID=

# API key de la app de Last.fm (Música, D62): https://www.last.fm/api/account/create
LASTFM_API_KEY=

# client id de la app de MyAnimeList (Anime y manga, D62): https://myanimelist.net/apiconfig
MAL_CLIENT_ID=
