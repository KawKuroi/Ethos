# Plantilla de variables de entorno. Copiar a .env y rellenar.
# NUNCA poner valores reales aquí ni versionar el .env.

# Entorno de ejecución: development | production
ENVIRONMENT=development

# Supabase (proyecto de datos, auth y secretos)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Secreto JWT del proyecto (Supabase: Project Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=

# Llave de cifrado simétrico para tokens de terceros (Fernet/AES-GCM)
ENCRYPTION_KEY=

# Steam Web API key (servidor; nunca expuesta al cliente)
STEAM_API_KEY=
